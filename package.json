{
	"name": "mkjs",
	"version": "1.0.0",
	"main": "index.js",
	"license": "MIT",
	"scripts": {
		"build": "webpack --mode production",
		"build:watch:dev": "webpack --mode development --watch",
		"build:watch:prod": "webpack --mode production --watch",
		"dev": "node devserver.js",
		"lint": "eslint \"src/**/*.ts\" global.d.ts",
		"lint:fix": "eslint \"src/**/*.ts\" global.d.ts --fix",
		"format": "prettier --write \"**/*.{ts,js,json,html,md}\"",
		"format:check": "prettier --check \"**/*.{ts,js,json,html,md}\"",
		"test": "vitest run",
		"test:watch": "vitest",
		"extract:rom": "node scripts/extract-mkds-rom-node.mjs"
	},
	"dependencies": {
		"gl-matrix": "3.4.3",
		"indexeddbshim": "^16.1.0",
		"live-server": "^1.2.2",
		"ts-loader": "^9.4.3",
		"typescript": "^5.1.3",
		"webpack": "^5.86.0",
		"webpack-cli": "^5.1.4",
		"webpack-dev-server": "^4.15.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^26.0.0",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.6.0",
		"prettier": "^3.8.4",
		"typescript-eslint": "^8.61.1",
		"vitest": "^4.1.9"
	}
}
